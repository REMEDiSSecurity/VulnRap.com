{
  "name": "workspace",
  "version": "3.8.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "postinstall": "node scripts/codegen-if-stale.mjs && tsc --build",
    "prepare": "node scripts/install-git-hooks.mjs",
    "codegen": "pnpm --filter @workspace/api-spec run codegen",
    "verify:codegen": "node scripts/verify-codegen.mjs",
    "verify:go-sdk-spec": "node scripts/check-go-sdk-openapi-drift.mjs",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run verify:codegen && pnpm run verify:go-sdk-spec && pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "test": "pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "cache-stats": "node scripts/build-if-stale-stats.mjs"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "lefthook": "^2.1.6",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.1"
  }
}
