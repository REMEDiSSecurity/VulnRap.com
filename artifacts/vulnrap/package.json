{
  "name": "@workspace/vulnrap",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "VITE_CALIBRATION_TOKEN=\"${VITE_CALIBRATION_TOKEN:-e2e-calibration-token}\" vite --config vite.config.ts --host 0.0.0.0",
    "build": "vite build --config vite.config.ts && (playwright install chromium >/dev/null 2>&1 || true) && node scripts/prerender.mjs",
    "build:no-prerender": "vite build --config vite.config.ts",
    "prerender": "node scripts/prerender.mjs",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",
    "typecheck": "pnpm -w run typecheck:libs && tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run && pnpm run test:e2e",
    "test:watch": "vitest",
    "test:unit": "vitest run",
    "test:e2e": "playwright test --config playwright.config.ts",
    "i18n:check": "node scripts/i18n-check.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-progress": "^1.1.3",
    "@radix-ui/react-radio-group": "^1.2.4",
    "@radix-ui/react-separator": "^1.1.3",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-toast": "^1.2.7",
    "@radix-ui/react-tooltip": "^1.2.0",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@workspace/api-client-react": "workspace:*",
    "@workspace/avri-rubric": "workspace:*",
    "axe-core": "^4.11.4",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "framer-motion": "catalog:",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "recharts": "^3.8.1",
    "rollup-plugin-visualizer": "^6.0.4",
    "sharp": "^0.34.5",
    "tailwind-merge": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "^1.4.0",
    "typescript-eslint": "^8.59.1",
    "vite": "catalog:",
    "vitest": "^4.1.4",
    "zod": "catalog:"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "html2pdf.js": "^0.14.0",
    "qrcode-generator": "^2.0.4",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1"
  }
}
