{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && export CALIBRATION_TOKEN=\"${CALIBRATION_TOKEN:-e2e-calibration-token}\" && node ./build.mjs --watch",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "pnpm -w run typecheck:libs && tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "seed": "node --enable-source-maps ./dist/seed.mjs",
    "backfill:vulnrap": "node --enable-source-maps ./dist/backfill-vulnrap-cli.mjs",
    "backfill:avri-family": "node --enable-source-maps ./dist/backfill-avri-family.mjs",
    "backfill:fabricated-evidence": "node --enable-source-maps ./dist/backfill-fabricated-evidence.mjs",
    "backfill:engine-versions": "node --enable-source-maps ./dist/backfill-engine-versions.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.74.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.216.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.216.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@resvg/resvg-js": "^2.6.2",
    "@workspace/api-zod": "workspace:*",
    "@workspace/avri-rubric": "workspace:*",
    "@workspace/db": "workspace:*",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "openai": "^6.34.0",
    "pdf-parse-new": "^2.0.0",
    "pino": "^9",
    "pino-http": "^10",
    "prom-client": "^15.1.3",
    "swagger-ui-express": "^5.0.1",
    "ulid": "^3.0.2",
    "yamljs": "^0.3.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "catalog:",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "vitest": "^4.1.4"
  }
}
