# Discord application credentials — find these at https://discord.com/developers/applications
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# Optional: register the slash command to a single guild for instant updates while developing.
# Leave empty for global registration (takes up to 1 hour to propagate).
DISCORD_GUILD_ID=

# VulnRap API base URL. Override only if you self-host.
VULNRAP_API_BASE=https://vulnrap.com/api

# Public web URL used when building "Open report" links. Override only if you self-host.
VULNRAP_PUBLIC_URL=https://vulnrap.com
