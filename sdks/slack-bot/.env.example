# Slack app credentials — find these at https://api.slack.com/apps
# Bot User OAuth Token (starts with xoxb-)
SLACK_BOT_TOKEN=

# App-level token with the connections:write scope (starts with xapp-).
# Required for Socket Mode so the bot does not need a public HTTPS endpoint.
SLACK_APP_TOKEN=

# Signing secret from the "Basic Information" page. Used by Bolt to verify
# inbound requests when running in HTTP mode; harmless to set in Socket Mode.
SLACK_SIGNING_SECRET=

# VulnRap API base URL. Override only if you self-host.
VULNRAP_API_BASE=https://vulnrap.com/api

# Public web URL used when building "Open report" links. Override only if you self-host.
VULNRAP_PUBLIC_URL=https://vulnrap.com
