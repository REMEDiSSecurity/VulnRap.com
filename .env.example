# ---------------------------------------------------------------------------
# Database connection.
#
# This value is for HOST-SIDE development only — it points at a Postgres
# reachable on `localhost`, which is correct when you run
# `pnpm --filter @workspace/api-server run dev` directly on the host
# (typically alongside `docker compose --profile db-only up`).
#
# When you run the FULL STACK via `docker compose up` (the self-hosted
# flow), this variable is IGNORED. The compose file wires the `app`
# container at the bundled `db` service explicitly so the app never
# accidentally targets itself. To override the in-container DB target,
# either ship a `docker-compose.override.yml` setting DATABASE_URL on the
# `app` service, or run the image directly with `-e DATABASE_URL=...`.
# See docs/self-hosting.md for details.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://vulnrap:vulnrap@localhost:5432/vulnrap

# Bundled Postgres credentials. Used by the `db` service in
# docker-compose.yml AND by the in-container DATABASE_URL the compose
# file builds for the app — change POSTGRES_PASSWORD here and both
# sides stay in sync. No effect on host-side dev.
POSTGRES_USER=vulnrap
POSTGRES_PASSWORD=vulnrap
POSTGRES_DB=vulnrap
POSTGRES_PORT=5432

PORT=8080

# PUBLIC_URL / ALLOWED_ORIGINS: the values below are tuned for HOST-SIDE
# `pnpm dev`, where the SPA runs on Vite at :5173 and proxies to the
# api-server. For the SELF-HOSTED `docker compose up` flow the SPA is
# served BY the api-server on $PORT (default 8080), so you'll want:
#   PUBLIC_URL=http://localhost:8080
#   ALLOWED_ORIGINS=http://localhost:8080
# (or your public origin once you put a TLS terminator in front).
# See docs/self-hosting.md for the full self-host config matrix.
PUBLIC_URL=http://localhost:5173

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Task #724 — Observability (see docs/observability.md).
# Prometheus scrape endpoint at GET /api/metrics. Default ON; set false to disable.
# METRICS_ENABLED=true
# When set, /api/metrics requires `Authorization: Bearer <METRICS_TOKEN>`.
# METRICS_TOKEN=
# OpenTelemetry: only loaded when an OTLP/HTTP traces endpoint is set.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_SERVICE_NAME=api-server

# LLM-enhanced slop detection (optional — heuristic-only scoring works without it)
# Set OPENAI_API_KEY to enable LLM semantic analysis layer
# Works with OpenAI, Azure OpenAI, or any OpenAI-compatible API (Ollama, vLLM, etc.)
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Task #725 — External-API resilience (timeouts, retries, circuit breakers)
# Per-provider tuning for outbound calls (OpenAI, GitHub, NVD).
# See docs/resilience.md for full semantics.
# OPENAI_TIMEOUT_MS=10000
# OPENAI_MAX_RETRIES=3
# OPENAI_BREAKER_THRESHOLD=5
# OPENAI_BREAKER_RESET_MS=30000
# GITHUB_TIMEOUT_MS=10000
# GITHUB_MAX_RETRIES=3
# GITHUB_BREAKER_THRESHOLD=5
# GITHUB_BREAKER_RESET_MS=30000
# NVD_TIMEOUT_MS=10000
# NVD_MAX_RETRIES=3
# NVD_BREAKER_THRESHOLD=5
# NVD_BREAKER_RESET_MS=30000
