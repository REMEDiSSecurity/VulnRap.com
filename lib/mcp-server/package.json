{
  "name": "@workspace/mcp-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "vulnrap-mcp": "./dist/index.js"
  },
  "exports": {
    ".": "./src/index.ts",
    "./tools": "./src/tools.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node ./dist/index.js",
    "dev": "tsx ./src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@workspace/api-zod": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "~5.9.2",
    "vitest": "^4.1.4"
  }
}
