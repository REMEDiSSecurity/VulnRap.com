{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./migrate": "./src/migrate.ts"
  },
  "scripts": {
    "generate": "drizzle-kit generate --config ./drizzle.config.ts",
    "migrate": "tsx ./src/migrate.ts",
    "push": "node ./scripts/push-guard.mjs && drizzle-kit push --config ./drizzle.config.ts",
    "push:dev": "node ./scripts/push-guard.mjs && drizzle-kit push --config ./drizzle.config.ts",
    "push-force": "node ./scripts/push-guard.mjs && drizzle-kit push --force --config ./drizzle.config.ts",
    "check": "drizzle-kit check --config ./drizzle.config.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "catalog:",
    "vitest": "^4.1.4"
  }
}
